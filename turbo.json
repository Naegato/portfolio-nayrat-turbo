{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "build/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "@repo/docker#up": {
      "cache": false
    },
    "@repo/docker#dev": {
      "dependsOn": ["@repo/docker#up"],
      "cache": false,
      "persistent": true
    },
    "dev": {
      "dependsOn": ["@repo/docker#up"],
      "cache": false,
      "persistent": true
    }
  }
}
